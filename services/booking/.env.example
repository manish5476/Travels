# ── Vendor Service (.env) ─────────────────────────────────────────────────
NODE_ENV=development
PORT=8012
SERVICE_NAME=vendor-service
 
MONGO_URI=mongodb://localhost:27017/tripparty
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
 
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
AWS_REGION=ap-south-1
AWS_S3_BUCKET=tripparty-media
INTERNAL_SERVICE_SECRET=your-strong-random-secret-here
 
# ── Booking Service (.env) ────────────────────────────────────────────────
PORT=8013
SERVICE_NAME=booking-service
 
MONGO_URI=mongodb://localhost:27017/tripparty
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
 
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
 
# Get these from Razorpay dashboard
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
 
VENDOR_SERVICE_URL=http://vendor:8012
INTERNAL_SERVICE_SECRET=your-strong-random-secret-here

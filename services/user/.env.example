
  # ── SERVER ───────────────────────────────────────────────
  PORT=8002
  NODE_ENV=development
  LOG_LEVEL=info
  SERVICE_NAME=user-service
  
  # ── MONGODB ──────────────────────────────────────────────
  MONGODB_URI=mongodb://admin:devpass@localhost:27017/tripparty_user?authSource=admin
  
  # ── REDIS ────────────────────────────────────────────────
  REDIS_URL=redis://localhost:6379
  REDIS_DB=1
  
  # ── JWT PUBLIC KEY (same key as Auth Service — only public key needed) ──
  JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"
  JWT_ISSUER=tripparty.auth
  JWT_AUDIENCE=tripparty.api
  
  # ── AWS S3 (avatar storage) ───────────────────────────────
  AWS_REGION=ap-south-1
  AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
  AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
  S3_AVATAR_BUCKET=tripparty-avatars-dev
  CDN_BASE_URL=https://d1234567890.cloudfront.net
  
  # ── KAFKA ────────────────────────────────────────────────
  KAFKA_BROKERS=localhost:9092
  
  # ── INTERNAL URLS ────────────────────────────────────────
  AUTH_SERVICE_URL=http://localhost:8001
  
  # ── CACHE TTLs (seconds) ─────────────────────────────────
  CACHE_PROFILE_TTL=300
  CACHE_FOLLOWERS_TTL=60


  PORT=8003
  NODE_ENV=development
  LOG_LEVEL=info
  SERVICE_NAME=feed-service
  MONGODB_URI=mongodb://admin:devpass@localhost:27017/tripparty_post?authSource=admin
  # Feed shares Post Service DB (reads Post collection)
  REDIS_URL=redis://localhost:6379
  REDIS_DB=3
  JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"
  JWT_ISSUER=tripparty.auth
  JWT_AUDIENCE=tripparty.api
  KAFKA_BROKERS=localhost:9092
  USER_SERVICE_URL=http://localhost:8002
  POST_SERVICE_URL=http://localhost:8004
  # Feed tuning
  FEED_CANDIDATE_POOL=500
  FEED_MAX_FOLLOWING_CANDIDATES=300
  FEED_MAX_TRENDING_CANDIDATES=50
  FEED_MAX_INTEREST_CANDIDATES=150
  FEED_TTL_SECONDS=86400
  FEED_MAX_SIZE=500
  INFLUENCER_THRESHOLD=10000
  BLOOM_FALSE_POSITIVE=0.01
  BLOOM_EXPECTED_ITEMS=10000

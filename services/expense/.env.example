# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8011
LOG_LEVEL=info
SERVICE_NAME=expense-service
 
# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:devpass@localhost:27017/tripparty?authSource=admin
 
# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
 
# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
 
# ── Auth (RS256 public key — same key used by all services) ──────────────────
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQ...
-----END PUBLIC KEY-----"
 
# ── Service secrets ──────────────────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=replace-with-strong-random-secret
TRIP_SERVICE_URL=http://trip:8009
PAYMENT_SERVICE_URL=http://payment:8014


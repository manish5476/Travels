# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8010
LOG_LEVEL=debug
SERVICE_NAME=map-service
 
# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:devpass@localhost:27017/tripparty?authSource=admin
 
# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
 
# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
 
# ── Auth (same RS256 public key used by all services) ────────────────────────
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQ...
-----END PUBLIC KEY-----"
 
# ── Service secrets ──────────────────────────────────────────────────────────
INTERNAL_SECRET=replace-with-strong-random-secret
TRIP_SERVICE_URL=http://trip:8009
 
# ── Live location config ─────────────────────────────────────────────────────
# How long a live location ping persists in Redis before user is considered offline
LIVE_LOCATION_TTL_SEC=30
# How often the geofence background check runs
GEOFENCE_CHECK_INTERVAL_SEC=15
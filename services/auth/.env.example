# ─── SERVER ──────────────────────────────────────────────────
PORT=8001
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=auth-service

# ─── MONGODB ─────────────────────────────────────────────────
# Local (docker-compose.dev.yml):
MONGODB_URI=mongodb://admin:devpass@localhost:27017/tripparty_auth?authSource=admin
# Atlas (production):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tripparty_auth

# ─── REDIS ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ─── JWT (RSA Key Pair) ───────────────────────────────────────
# Step 1: node -e "const c=require('crypto');const {privateKey,publicKey}=c.generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});require('fs').writeFileSync('private.pem',privateKey);require('fs').writeFileSync('public.pem',publicKey);"
# Step 2: Copy content, replacing actual newlines with \n
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...rest_of_key...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...rest_of_key...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=tripparty.auth
JWT_AUDIENCE=tripparty.api

# ─── FIREBASE ADMIN (Phone Auth Gateway) ─────────────────────
# Firebase is used ONLY to verify phone OTPs. We do not use Firebase sessions.
# We still issue our own RS256 JWT tokens after Firebase verification.
#
# Option A — Recommended for production (base64-encoded service account JSON):
#   1. Go to Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" → download JSON
#   3. Encode: node -e "console.log(require('fs').readFileSync('serviceAccount.json').toString('base64'))"
#   4. Paste the output below:
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option B — Local dev (Application Default Credentials):
#   Set this to the path of your downloaded service account JSON file.
#   The SDK will pick it up automatically if FIREBASE_SERVICE_ACCOUNT_BASE64 is not set.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ─── GOOGLE OAUTH ────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx

# ─── KAFKA ───────────────────────────────────────────────────
# Local (docker-compose): kafka:9092
# AWS MSK (production):   broker1.msk.region.amazonaws.com:9092
KAFKA_BROKERS=localhost:9092

# ─── RATE LIMITING ───────────────────────────────────────────
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5